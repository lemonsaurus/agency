#!/usr/bin/env bash
# claudejail — Run Claude Code in a bubblewrap sandbox restricted to $PWD
set -euo pipefail

# --- Preflight checks -------------------------------------------------------

if ! command -v bwrap &>/dev/null; then
    echo "error: bubblewrap is not installed" >&2
    echo "  sudo apt install bubblewrap" >&2
    exit 1
fi

if ! command -v claude &>/dev/null; then
    echo "error: claude is not installed" >&2
    exit 1
fi

# --- Resolve paths -----------------------------------------------------------

CWD="$(pwd -P)"
CLAUDE_BIN="$(command -v claude)"
CLAUDE_BIN_REAL="$(readlink -f "$CLAUDE_BIN")"
CLAUDE_BIN_DIR="$(dirname "$CLAUDE_BIN_REAL")"

# Resolve nvm/node path if available
NODE_DIR=""
if command -v node &>/dev/null; then
    NODE_REAL="$(readlink -f "$(command -v node)")"
    NODE_DIR="$(dirname "$(dirname "$NODE_REAL")")"
fi

# --- Build bwrap arguments ---------------------------------------------------

args=(
    # --- Filesystem: build up from nothing ---

    # System directories (read-only)
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind /lib /lib
    --ro-bind /etc /etc

    # Minimal devices and proc
    --dev /dev
    --proc /proc
    --tmpfs /tmp
    --tmpfs /run

    # --- Home: deny everything, then whitelist ---

    # Empty home as base
    --tmpfs "$HOME"

    # Working directory (read-write — Claude edits code here)
    --bind "$CWD" "$CWD"

    # Claude config/state/memory (read-write — Claude writes here)
    --bind "$HOME/.claude" "$HOME/.claude"

    # Claude binary and its installation
    --ro-bind "$CLAUDE_BIN_DIR" "$CLAUDE_BIN_DIR"
)

# Claude Code 2.x keeps auth + settings in ~/.claude.json (a single file
# directly in $HOME, not inside ~/.claude/). Our --tmpfs $HOME hides it,
# so logins don't persist across sandbox invocations. Bind it through.
if [[ -f "$HOME/.claude.json" ]]; then
    args+=(--bind "$HOME/.claude.json" "$HOME/.claude.json")
fi

# /lib64 layout differs by distro: Fedora/RHEL have /lib64 as a symlink
# into /usr/lib64, Debian/Ubuntu have it as a real directory containing
# the ELF dynamic linker. Bind whatever the host has; fall back to the
# Fedora-style symlink only on hosts without /lib64.
if [[ -e /lib64 ]]; then
    args+=(--ro-bind /lib64 /lib64)
else
    args+=(--symlink usr/lib64 /lib64)
fi

# /etc/resolv.conf often symlinks into /run (systemd-resolved,
# NetworkManager) on modern Debian/Ubuntu. Our --tmpfs /run wipes that
# target, so DNS breaks inside the sandbox and Claude can't reach
# api.anthropic.com. We can't bind-mount over /etc/resolv.conf because
# bwrap follows the symlink and would try to create the file at the
# (now-missing) target. Instead, bind the real file at its actual host
# path so the symlink inside the sandbox resolves correctly.
if [[ -L /etc/resolv.conf ]]; then
    real_resolv="$(readlink -f /etc/resolv.conf)"
    [[ -f "$real_resolv" ]] && args+=(--ro-bind "$real_resolv" "$real_resolv")
fi

# Symlink claude into ~/.local/bin if it lives there (common setup)
if [[ "$CLAUDE_BIN" != "$CLAUDE_BIN_REAL" ]]; then
    args+=(--ro-bind "$(dirname "$CLAUDE_BIN")" "$(dirname "$CLAUDE_BIN")")
fi

# Claude runtime data (read-only)
if [[ -d "$HOME/.local/share/claude" ]]; then
    args+=(--ro-bind "$HOME/.local/share/claude" "$HOME/.local/share/claude")
fi

# Node.js via nvm (read-only — Claude needs node)
if [[ -n "$NODE_DIR" ]]; then
    args+=(--ro-bind "$NODE_DIR" "$NODE_DIR")
fi
if [[ -d "$HOME/.nvm" ]]; then
    args+=(--ro-bind "$HOME/.nvm" "$HOME/.nvm")
fi

# Git config (read-only)
if [[ -f "$HOME/.gitconfig" ]]; then
    args+=(--ro-bind "$HOME/.gitconfig" "$HOME/.gitconfig")
fi
if [[ -d "$HOME/.config/git" ]]; then
    args+=(--ro-bind "$HOME/.config/git" "$HOME/.config/git")
fi

# SSH keys (read-only — for git operations)
if [[ -d "$HOME/.ssh" ]]; then
    args+=(--ro-bind "$HOME/.ssh" "$HOME/.ssh")
fi

# Agency socket (read-write — so Claude can self-spawn)
if [[ -n "${AGENCY_SOCKET:-}" && -S "$AGENCY_SOCKET" ]]; then
    args+=(--bind "$(dirname "$AGENCY_SOCKET")" "$(dirname "$AGENCY_SOCKET")")
fi

args+=(
    # --- Security hardening ---

    # New PID namespace
    --unshare-pid

    # IPC namespace isolation
    --unshare-ipc

    # UTS namespace (hostname isolation)
    --unshare-uts

    # Block privilege escalation
    --new-session

    # Drop all capabilities
    --cap-drop ALL

    # Die when parent dies
    --die-with-parent

    # Set working directory
    --chdir "$CWD"
)

# --- Launch sandboxed Claude -------------------------------------------------

exec bwrap "${args[@]}" \
    claude \
    --allowedTools Bash Edit Write Read Glob Grep WebFetch WebSearch NotebookEdit Agent \
    "$@"
